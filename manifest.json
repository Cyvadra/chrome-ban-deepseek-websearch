{
  "manifest_version": 3,
  "name": "Disable DeepSeek Web Search",
  "version": "1.0.0",
  "description": "Turns off DeepSeek Search toggle automatically on page load.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "DeepSeek Search Toggle",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}